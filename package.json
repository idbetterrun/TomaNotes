{
  "name": "tomanotes",
  "version": "0.1.1",
  "author": "Tan Qinghua <douyin@idbetterrun>",
  "description": "TomaNotes - Secure, encrypted knowledge base.",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "build:mac": "npm run build:web && electron-builder --mac",
    "build:win": "npm run build:web && electron-builder --win",
    "start": "electron ."
  },
  "build": {
    "appId": "com.tomanotes.app",
    "productName": "TomaNotes",
    "copyright": "Copyright © 2026 Tan Qinghua",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "public/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "public/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^24.13.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.2.2",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.0",
    "@tiptap/extension-character-count": "^3.22.0",
    "@tiptap/extension-code-block-lowlight": "^3.22.0",
    "@tiptap/extension-color": "^3.22.0",
    "@tiptap/extension-highlight": "^3.22.0",
    "@tiptap/extension-image": "^3.22.0",
    "@tiptap/extension-link": "^3.22.0",
    "@tiptap/extension-placeholder": "^3.22.0",
    "@tiptap/extension-subscript": "^3.22.0",
    "@tiptap/extension-superscript": "^3.22.0",
    "@tiptap/extension-table": "^3.22.0",
    "@tiptap/extension-table-cell": "^3.22.0",
    "@tiptap/extension-table-header": "^3.22.0",
    "@tiptap/extension-table-row": "^3.22.0",
    "@tiptap/extension-task-item": "^3.22.0",
    "@tiptap/extension-task-list": "^3.22.0",
    "@tiptap/extension-text-align": "^3.22.0",
    "@tiptap/extension-text-style": "^3.22.0",
    "@tiptap/extension-typography": "^3.22.0",
    "@tiptap/extension-underline": "^3.22.0",
    "@tiptap/pm": "^3.22.0",
    "@tiptap/react": "^3.22.0",
    "@tiptap/starter-kit": "^3.22.0",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/codemirror-themes": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "framer-motion": "^12.38.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "react-markdown": "^10.1.0",
    "react-rnd": "^10.5.3",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  }
}
